generator client {
 provider = "prisma-client-js"
}

datasource db {
 provider = "sqlite"
 url = "file:./dev.db"
}

model GuestWish {
 id Int @id @default(autoincrement())
 name String
 message String
 createdAt DateTime @default(now())
}

model Gallery {
 id Int @id @default(autoincrement())
 image String
}
